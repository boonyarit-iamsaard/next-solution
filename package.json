{
  "name": "next-solution",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "ci": "prettier --check . && next lint && tsc --noEmit",
    "db:generate": "dotenvx run -- drizzle-kit generate",
    "db:migrate": "dotenvx run -- drizzle-kit migrate",
    "db:push": "dotenvx run -- drizzle-kit push",
    "db:studio": "dotenvx run -- drizzle-kit studio",
    "dev": "next dev --turbopack",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "next lint --fix",
    "lint:check": "next lint",
    "prepare": "husky || true",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@better-fetch/fetch": "^1.1.18",
    "@dotenvx/dotenvx": "^1.39.0",
    "@hookform/resolvers": "^4.1.3",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@t3-oss/env-nextjs": "^0.12.0",
    "better-auth": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.41.0",
    "lucide-react": "^0.483.0",
    "next": "^15.2.3",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.55.0",
    "tailwind-merge": "^3.0.2",
    "tw-animate-css": "^1.2.4",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@ianvs/prettier-plugin-sort-imports": "^4.4.1",
    "@stylistic/eslint-plugin-js": "^4.2.0",
    "@tailwindcss/postcss": "^4.0.14",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.3",
    "eslint-config-prettier": "^10.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "tailwindcss": "^4.0.14",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "npm": "please-use-pnpm",
    "yarn": "please-use-pnpm",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.6.5"
}
